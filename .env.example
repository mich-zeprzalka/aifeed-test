# ============================================
# AiFeed — Zmienne Środowiskowe
# Skopiuj do .env.local i uzupełnij wartości
# ============================================

# --- Supabase ---
# Dashboard: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenRouter API (generowanie artykułów) ---
# Klucz: https://openrouter.ai/keys
# Model: anthropic/claude-sonnet-4 (konfiguracja w src/lib/ai/writer.ts)
OPENROUTER_API_KEY=sk-or-v1-...

# --- Ochrona endpointów ---
# Dowolny string chroniący /api/cron/generate i /api/cron/seed
CRON_SECRET=your-random-secret-here

# --- URL serwisu ---
# Używany w SEO, sitemap, RSS feed, metadanych Open Graph
NEXT_PUBLIC_SITE_URL=http://localhost:3000
